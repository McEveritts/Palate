// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id          String       @id @default(cuid())
  name        String       // e.g. "The McEveritts' Kitchen"
  members     User[]
  recipes     Recipe[]
  inviteCodes InviteCode[]
  createdAt   DateTime     @default(now())
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique // 8-char hex
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   String    // userId of the inviter
  expiresAt   DateTime  // 48h from creation
  usedAt      DateTime? // null until redeemed
  usedBy      String?   // userId of the redeemer
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  image         String?
  emailVerified DateTime?
  
  // Household membership
  householdId   String?
  household     Household?      @relation(fields: [householdId], references: [id])

  // Relations
  config        UserConfig?
  chatSessions  ChatSession[]
  schedule      ScheduledMeal[]
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime        @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Cryptographic Storage for Google Cloud / Gemma-4 Keys
  encryptedGcpKey   String?  // AES-256-GCM encrypted string
  authTag           String?  // GCM Auth Tag for integrity verification
  iv                String?  // Initialization Vector
  
  metricSystem      Boolean  @default(true)

  // Google Calendar Integration
  googleCalendarId  String?
  googleCalendarSyncEnabled Boolean @default(false)
}

model Recipe {
  id              String   @id @default(cuid())
  householdId     String
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  
  slug            String
  title           String
  markdown        String   // Recipe content
  frontmatter     Json     // Macros, USDA status, tags
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  scheduledMeals  ScheduledMeal[]
  
  @@unique([householdId, slug]) // Enforces unique recipe names per household
}

model ScheduledMeal {
  id            String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  recipeId      String
  recipe        Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  date          DateTime // The specific day on the calendar
  mealType      String   // 'Breakfast', 'Lunch', 'Dinner', 'Snack'
  plannedYield  Float    @default(1.0) // E.g., eating 2 portions of an 8-portion meal
  
  // Self-relations for parentMealId (DAG for leftovers/batch cooking)
  parentMealId  String?
  parentMeal    ScheduledMeal?   @relation("MealDAG", fields: [parentMealId], references: [id], onDelete: Cascade)
  childMeals    ScheduledMeal[]  @relation("MealDAG")

  // Google Calendar integration
  googleEventId String?
}

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String        // Auto-generated by AI (e.g., "Sunday Meal Prep")
  messages    ChatMessage[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          String      // "user" | "model"
  content       String      // The message text
  thought       String?     // Preserved Gemma-4 <thought> blocks
  
  createdAt     DateTime    @default(now())
}
